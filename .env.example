# ============================================
# AMBIENTE E SERVIDOR
# ============================================
NODE_ENV=development
PORT=3000
VITE_API_TIMEOUT=10000

# ============================================
# SUPABASE
# ============================================
# Obter em: supabase.com → Dashboard → Settings → API
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# EMAIL — SENDGRID (Opcional)
# ============================================
# ⚠️  Para ativar: obter API key em sendgrid.com
SENDGRID_API_KEY=SG.xxxx...
SENDGRID_FROM_EMAIL=noreply@agro.com
SENDGRID_FROM_NAME=AgroColetivo

# ============================================
# EMAIL — GMAIL SMTP (Fallback ativo)
# ============================================
# ⚠️  Use Google App Password, NÃO a senha de login
# Gerar em: myaccount.google.com → Segurança → Senhas de app
# Pré-requisito: 2-Step Verification ativado
GMAIL_USER=seu-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587

# ============================================
# APLICAÇÃO
# ============================================
VITE_ENABLE_HTTPS_ONLY=false
VITE_ENABLE_CORS=true
VITE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://seu-app.onrender.com

# ============================================
# RATE LIMITING
# ============================================
VITE_RATE_LIMIT_REQUESTS=10
VITE_RATE_LIMIT_WINDOW_MS=60000

# ============================================
# KEEP-ALIVE (Render - previne auto-sleep)
# ============================================
# Hook useKeepAlive.js já lê location.origin automaticamente
# Desabilita em localhost, ativa em production automaticamente
