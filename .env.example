# ============================================
# ⚠️  INSTRUÇÕES IMPORTANTES
# ============================================
# Este arquivo é um TEMPLATE de exemplo
# Para RENDER: copie este arquivo como .env.local e preencha os valores
# Depois importe para o Render Dashboard → Environment Variables
#
# NUNCA commite arquivo .env com valores reais no Git!
# Use este .env.example apenas como referência

# ============================================
# AMBIENTE E SERVIDOR
# ============================================
NODE_ENV=development
PORT=3000
VITE_API_TIMEOUT=10000

# ============================================
# SUPABASE (Obrigatório)
# ============================================
# Como obter:
# 1. Acesse: https://supabase.com → Dashboard
# 2. Vá para: Settings → API
# 3. Copie: Project URL e Anon Key
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# EMAIL — GMAIL SMTP (Obrigatório para funcionar)
# ============================================
# ⚠️  Use GOOGLE APP PASSWORD, NÃO a senha de login!
# Como obter:
# 1. Acesse: https://myaccount.google.com/apppasswords
# 2. Pré-requisito: 2-Step Verification ativado
# 3. Selecione: Mail + Windows Computer
# 4. Copie a senha gerada (16 caracteres com espaços)
# 5. Cole abaixo sem os espaços (ou com, o código tira automaticamente)
#
# Exemplo de valor: dlskwqszofvtdfsz (ou dlsk wqsz ofvt dfsz)
GMAIL_USER=seu-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ============================================
# EMAIL — SENDGRID (Opcional)
# ============================================
# Se quiser usar SendGrid como provider principal:
# 1. Crie conta em: https://sendgrid.com
# 2. Gere API Key em: Settings → API Keys
# 3. Se vazio, usa apenas Gmail SMTP (recomendado)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@seu-dominio.com
SENDGRID_FROM_NAME=AgroColetivo

# ============================================
# APLICAÇÃO
# ============================================
VITE_ENABLE_HTTPS_ONLY=false
VITE_ENABLE_CORS=true
# Para Render, substitua "seu-app" pelo nome do seu serviço
VITE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://seu-app.onrender.com

# ============================================
# RATE LIMITING
# ============================================
VITE_RATE_LIMIT_REQUESTS=10
VITE_RATE_LIMIT_WINDOW_MS=60000
