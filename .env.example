# ============================================
# RENDER ENVIRONMENT VARIABLES
# ============================================
# Configure estas variáveis no Render Dashboard:
# Dashboard → Serviço "agrocoletivo" → Environment
#
# NUNCA commite este arquivo com valores reais!
# Este é apenas um TEMPLATE de referência.

# ============================================
# SUPABASE (Obrigatório)
# ============================================
# Onde obter:
# 1. Acesse: https://supabase.com → Dashboard
# 2. Vá para: Settings → API
# 3. Copie: Project URL e Anon Key
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# EMAIL — GMAIL SMTP (OBRIGATÓRIO)
# ============================================
# ⚠️  Use GOOGLE APP PASSWORD, NÃO a senha de login!
#
# Como obter:
# 1. Acesse: https://myaccount.google.com/apppasswords
# 2. Pré-requisito: Ativar 2-Step Verification em sua conta Google
# 3. Selecione: Mail + Windows Computer (ou seu dispositivo)
# 4. Google gera uma senha de 16 caracteres (ex: dlsk wqsz ofvt dfsz)
# 5. Cole a senha abaixo (com ou sem espaços - o código tira automaticamente)
#
# Sem isto, emails NÃO funcionam!
GMAIL_USER=seu-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ============================================
# EMAIL — SENDGRID (Opcional)
# ============================================
# Se deixar vazio, usa apenas Gmail SMTP (recomendado)
# Para ativar SendGrid como provider principal:
# 1. Crie conta: https://sendgrid.com
# 2. Gere API Key: Settings → API Keys → Create API Key
# 3. Cole a chave abaixo
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
