    "start": "npm run build && node server.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "dompurify": "^3.3.3",
    "express": "^5.2.1",
    "lucide-react": "^0.263.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "terser": "^5.46.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
